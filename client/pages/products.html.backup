    <script src="../js/config.js"></script>
    <script src="../js/auth-helper.js"></script>
    <script src="../js/cache-manager.js"></script>
    <script src="../js/api-batcher.js"></script>
    <script src="../js/debounce.js"></script>
    <script src="../js/cart.js"></script>
    <script src="../js/header.js"></script>
    <script src="../js/mobile-header.js"></script>
    
    <!-- Main products page script -->
    <script>
        // Helper function to fix URLs to point to server
        function fixServerUrl(url) {
            if (!url) return url;
            return url.startsWith('/') ? `${API_BASE}${url}` : url;
        }

        // Make the helper function globally available
        window.fixServerUrl = fixServerUrl;

        // Initialize products page after DOM is ready and dependencies are loaded
        document.addEventListener('DOMContentLoaded', function() {
            initializeProductsPage();
        });

        async function initializeProductsPage() {
            // Products page functionality
            if (window.isProductsScriptRunning) return;
            window.isProductsScriptRunning = true;

            // Get DOM elements
            const productGrid = document.getElementById('product-grid');
            const resultsCount = document.getElementById('results-count');
            const loadingState = document.getElementById('loading-state');
            const globalSearchInput = document.getElementById('desktop-search-input');
            const globalSearchButton = document.getElementById('desktop-search-button');
            const sortSelect = document.getElementById('sort-select');
            const filterBadge = document.getElementById('filter-count-badge');
            const mobileFilterBadge = document.getElementById('mobile-filter-count-badge');
            const activeFiltersContainer = document.getElementById('active-filters-container');

            let allProducts = [];
            let filteredProducts = [];
            let currentCategory = null;

            // Filter state
            const filters = {
                searchQuery: '',
                priceBracket: 'all',
                conditions: new Set(),
                campusVerifiedOnly: false,
                sortBy: 'relevance'
            };

            // Create debounced fetch function for search
            const debouncedFetchProducts = window.debounce(async () => {
                await fetchProducts();
            }, 300);

            // Fetch products from API with caching and optimization
            async function fetchProducts() {
                const urlParams = new URLSearchParams(window.location.search);
                const categoryFromUrl = urlParams.get('category');
                const searchFromUrl = urlParams.get('q');
                
                // Extract category from clean URL path (e.g., /products/Electronics)
                let categoryFromPath = null;
                const pathParts = window.location.pathname.split('/');
                if (pathParts.length >= 3 && pathParts[1] === 'products' && pathParts[2]) {
                    categoryFromPath = decodeURIComponent(pathParts[2]);
                }

                // Use category from query string first (for backward compatibility), then path
                currentCategory = categoryFromUrl || categoryFromPath || null;

                if (searchFromUrl && globalSearchInput) {
                    globalSearchInput.value = searchFromUrl;
                    filters.searchQuery = searchFromUrl;
                }

                console.log('Fetching products with category:', currentCategory);

                // Generate cache key based on current filters
                const cacheKey = `products_${currentCategory || 'all'}_${filters.searchQuery || ''}_${filters.sortBy}`;
                
                // Try cache first
                if (window.cacheManager) {
                    const cachedProducts = window.cacheManager.getCachedApiResponse(cacheKey);
                    if (cachedProducts) {
                        console.log('📦 Cache hit for products:', cacheKey);
                        allProducts = cachedProducts.products || [];
                        filteredProducts = [...allProducts];
                        
                        if (allProducts.length === 0) {
                            showEmptyState();
                        } else {
                            applyFiltersAndRender();
                        }
                        return;
                    }
                }

                const url = currentCategory 
                    ? `${API_BASE}/products?category=${encodeURIComponent(currentCategory)}` 
                    : `${API_BASE}/products`;

                try {
                    loadingState.style.display = 'block';
                    if (productGrid) productGrid.style.display = 'none';

                    // Use API batcher if available, otherwise use regular fetch
                    let response;
                    if (window.apiBatcher && window.cacheManager) {
                        response = await window.apiBatcher.batchRequest(url, {
                            method: 'GET',
                            headers: { 'Content-Type': 'application/json' },
                            cache: true,
                            cacheKey: cacheKey
                        });
                    } else {
                        response = await fetch(url, {
                            method: 'GET',
                            headers: { 'Content-Type': 'application/json' }
                        });
                    }

                    if (response.ok) {
                        const data = await response.json();
                        allProducts = data.products || [];
                        filteredProducts = [...allProducts];

                        // Cache the results
                        if (window.cacheManager) {
                            window.cacheManager.cacheApiResponse(cacheKey, data);
                        }

                        if (allProducts.length === 0) {
                            showEmptyState();
                            return;
                        }

                        applyFiltersAndRender();
                    } else {
                        console.error('Failed to fetch products:', await response.json());
                        showErrorState();
                    }
                } catch (error) {
                    console.error('Error fetching products:', error);
                    showErrorState();
                } finally {
                    loadingState.style.display = 'none';
                    if (productGrid) productGrid.style.display = 'grid';
                }
            }

            function showEmptyState() {
                if (productGrid) {
                    productGrid.innerHTML = '<p class="text-center text-gray-600 col-span-full py-10">No products available yet. Check back soon for new campus listings.</p>';
                }
                if (resultsCount) {
                    resultsCount.textContent = '0 items found';
                }
            }

            function showErrorState() {
                if (productGrid) {
                    productGrid.innerHTML = '<p class="text-center text-gray-600 py-10">Error loading products. Please try again.</p>';
                }
                if (resultsCount) {
                    resultsCount.textContent = 'Error loading products';
                }
            }

            // Filter and sort products
            function productMatchesFilters(product) {
                // Category
                if (currentCategory && product.category !== currentCategory) return false;

                // Search query
                if (filters.searchQuery) {
                    const query = filters.searchQuery.toLowerCase();
                    const searchableText = [
                        product.name,
                        product.description,
                        product.category,
                        product.subcategory,
                        product.subject,
                        product.courseCode,
                        product.author,
                        product.brand,
                        product.sellerName
                    ].filter(Boolean).join(' ').toLowerCase();

                    if (!searchableText.includes(query)) return false;
                }

                // Price bracket
                if (filters.priceBracket !== 'all') {
                    const price = product.price || 0;
                    switch (filters.priceBracket) {
                        case 'under-100':
                            if (price >= 100) return false;
                            break;
                        case '100-500':
                            if (price < 100 || price > 500) return false;
                            break;
                        case '500-1000':
                            if (price < 500 || price > 1000) return false;
                            break;
                        case '1000-plus':
                            if (price <= 1000) return false;
                            break;
                    }
                }

                // Condition
                if (filters.conditions.size > 0) {
                    const condition = (product.condition || '').toLowerCase();
                    if (!Array.from(filters.conditions).some(c => condition === c.toLowerCase())) {
                        return false;
                    }
                }

                // Campus verified
                if (filters.campusVerifiedOnly) {
                    const isVerified = product.seller?.isStudentVerified || product.sellerVerified;
                    if (!isVerified) return false;
                }

                return true;
            }

            function sortProducts(products) {
                const items = [...products];
                switch (filters.sortBy) {
                    case 'price-asc':
                        return items.sort((a, b) => (a.price || 0) - (b.price || 0));
                    case 'price-desc':
                        return items.sort((a, b) => (b.price || 0) - (a.price || 0));
                    case 'newest':
                        return items.sort((a, b) => {
                            const aDate = new Date(a.createdAt || 0).getTime();
                            const bDate = new Date(b.createdAt || 0).getTime();
                            return bDate - aDate;
                        });
                    case 'relevance':
                    default:
                        return items;
                }
            }

            // Render products
            function renderProducts() {
                if (!productGrid) return;
                
                if (filteredProducts.length === 0) {
                    productGrid.innerHTML = '<p class="text-center text-gray-600 col-span-full py-10">No items match your criteria. Try adjusting your filters.</p>';
                    updateResultsSummary();
                    return;
                }

                productGrid.innerHTML = filteredProducts.map(product => {
                    const imageUrl = product.images && product.images[0]
                        ? window.optimizeImageUrl ? window.optimizeImageUrl(fixServerUrl(product.images[0]), 400, 300) : fixServerUrl(product.images[0])
                        : 'https://placehold.co/400x300?text=No+Image';

                    const isVerified = product.seller?.isStudentVerified || product.sellerVerified;
                    const isHotDeal = product.originalPrice && product.originalPrice > product.price;
                    const isOutOfStock = product.status === 'Out of Stock' || product.status === 'Sold';
                    const isPersistent = product.listingType === 'persistent';
                    const showInventory = isPersistent && product.inventory !== undefined;
                    const isLowStock = showInventory && product.inventoryTracking && product.inventory <= (product.lowStockThreshold || 1);

                    return `
                        <div class="product-card bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 overflow-hidden group flex flex-col h-full ${isOutOfStock ? 'opacity-75' : ''}">
                            <div class="relative aspect-square w-full bg-gray-50 overflow-hidden">
                                <img src="${imageUrl}" 
                                     alt="${product.name}" 
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                     width="300"
                                     height="300"
                                     loading="lazy" />
                                <div class="absolute top-2 left-2 flex gap-1">
                                    ${isVerified ? `
                                        <span class="bg-emerald-50 text-emerald-700 px-2 py-1 rounded-full text-[10px] font-semibold border border-emerald-200">
                                            <i class="fas fa-shield-check w-3 h-3"></i> Campus Verified
                                        </span>
                                    ` : ''}
                                    ${isHotDeal ? `
                                        <span class="bg-red-50 text-red-600 px-2 py-1 rounded-full text-[10px] font-semibold border border-red-200">
                                            <i class="fas fa-fire w-3 h-3"></i> Hot Deal
                                        </span>
                                    ` : ''}
                                    ${isPersistent ? `
                                        <span class="bg-blue-50 text-blue-700 px-2 py-1 rounded-full text-[10px] font-semibold border border-blue-200">
                                            <i class="fas fa-infinity w-3 h-3"></i> Multi-Stock
                                        </span>
                                    ` : ''}
                                    ${isOutOfStock ? `
                                        <span class="bg-gray-50 text-gray-700 px-2 py-1 rounded-full text-[10px] font-semibold border border-gray-200">
                                            <i class="fas fa-times-circle w-3 h-3"></i> ${product.status === 'Sold' ? 'Sold' : 'Out of Stock'}
                                        </span>
                                    ` : ''}
                                    ${isLowStock && !isOutOfStock ? `
                                        <span class="bg-orange-50 text-orange-700 px-2 py-1 rounded-full text-[10px] font-semibold border border-orange-200">
                                            <i class="fas fa-exclamation-triangle w-3 h-3"></i> Low Stock
                                        </span>
                                    ` : ''}
                                </div>
                                <div class="absolute top-2 right-2">
                                    <button class="bg-white/90 backdrop-blur-sm p-2 rounded-full hover:bg-white transition-colors">
                                        <i class="far fa-heart text-gray-600 hover:text-red-500"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="p-4 flex flex-col flex-1">
                                <h3 class="font-semibold text-gray-900 mb-1.5 line-clamp-2 text-[15px] leading-tight">${product.name}</h3>
                                <p class="text-xs text-gray-500 mb-4 line-clamp-2">${product.description}</p>
                                <div class="flex items-center justify-between mb-4 mt-auto">
                                    <div class="flex flex-col">
                                        <div class="flex items-center gap-2">
                                            <span class="text-lg font-bold text-navy">ZMW ${(product.price || 0).toFixed(2)}</span>
                                            ${product.originalPrice && product.originalPrice > product.price ? `
                                                <span class="text-xs text-gray-400 line-through">ZMW ${product.originalPrice.toFixed(2)}</span>
                                            ` : ''}
                                        </div>
                                        ${showInventory ? `
                                            <div class="text-xs text-gray-500 mt-1">
                                                <i class="fas fa-box w-3 h-3 mr-1"></i>
                                                ${product.inventory} in stock
                                                ${product.totalSold > 0 ? `• ${product.totalSold} sold` : ''}
                                            </div>
                                        ` : ''}
                                    </div>
                                    <span class="text-[10px] bg-gray-100 font-medium text-gray-600 px-2 py-1 rounded-full whitespace-nowrap self-start mt-1">${product.condition}</span>
                                </div>
                                <div class="flex flex-col gap-2 pt-3 border-t border-gray-100">
                                    <button class="w-full bg-button-gold text-white font-semibold py-2 px-4 rounded-lg hover-bg-button-gold transition-colors text-sm ${isOutOfStock ? 'opacity-50 cursor-not-allowed' : 'js-add-to-cart'}"
                                        ${isOutOfStock ? 'disabled' : ''}
                                        data-item-id="${product._id}"
                                        data-item-name="${product.name}"
                                        data-item-price="${product.price}"
                                        data-item-image="${product.images?.[0] || ''}"
                                        data-item-category="${product.category || ''}">
                                        ${isOutOfStock ? (product.status === 'Sold' ? 'Sold Out' : 'Out of Stock') : 'Add to Cart'}
                                    </button>
                                    <a href="/product/${product._id}" class="text-center text-navy hover:text-gold text-xs font-medium w-full py-1">View Details</a>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
                
                updateFilterBadges();
                updateResultsSummary();
            }

            function updateResultsSummary() {
                if (!resultsCount) return;
                const total = allProducts.length;
                const shown = filteredProducts.length;
                const label = currentCategory && currentCategory !== 'Other'
                    ? ` in ${currentCategory}`
                    : '';
                resultsCount.textContent = `${shown} of ${total} items found${label}`;
            }

            function updateFilterBadges() {
                let count = 0;
                const chips = [];

                if (filters.searchQuery) {
                    count++;
                    chips.push({ type: 'search', label: `Search: "${filters.searchQuery}"` });
                }
                if (filters.priceBracket !== 'all') {
                    count++;
                    const labelMap = {
                        'under-100': 'Under K100',
                        '100-500': 'K100 - K500',
                        '500-1000': 'K500 - K1,000',
                        '1000-plus': 'K1,000+'
                    };
                    chips.push({ type: 'price', label: labelMap[filters.priceBracket] });
                }
                if (filters.conditions.size > 0) {
                    count += filters.conditions.size;
                    filters.conditions.forEach(cond => chips.push({ type: 'condition', value: cond, label: cond }));
                }
                if (filters.campusVerifiedOnly) {
                    count++;
                    chips.push({ type: 'campus', label: 'Campus verified only' });
                }

                if (filterBadge) {
                    if (count > 0) {
                        filterBadge.classList.remove('hidden');
                        filterBadge.textContent = count;
                    } else {
                        filterBadge.classList.add('hidden');
                    }
                }
                if (mobileFilterBadge) {
                    if (count > 0) {
                        mobileFilterBadge.classList.remove('hidden');
                        mobileFilterBadge.textContent = count;
                    } else {
                        mobileFilterBadge.classList.add('hidden');
                    }
                }

                if (activeFiltersContainer) {
                    if (chips.length === 0) {
                        activeFiltersContainer.innerHTML = '<span class="text-xs text-gray-500">No filters applied. Showing all campus items.</span>';
                        return;
                    }
                    activeFiltersContainer.innerHTML = chips.map(chip => `
                        <button 
                            class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-100 text-[11px] text-gray-700 border border-gray-200 hover:border-red-400 hover:text-red-600 transition-colors"
                            data-filter-type="${chip.type}"
                            ${chip.value ? `data-filter-value="${chip.value}"` : ''}
                        >
                            <span>${chip.label}</span>
                            <i class="fas fa-times w-3 h-3"></i>
                        </button>
                    `).join('');
                }
            }

            function applyFiltersAndRender() {
                filteredProducts = sortProducts(allProducts.filter(productMatchesFilters));
                renderProducts();
            }

            // Event listeners
            if (globalSearchInput) {
                // Create debounced search handler
                const debouncedSearch = window.debounce((query) => {
                    filters.searchQuery = query;
                    applyFiltersAndRender();
                }, 300);

                globalSearchInput.addEventListener('input', (e) => {
                    const query = e.target.value.trim();
                    debouncedSearch(query);
                });

                globalSearchInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        // Immediate search on Enter
                        filters.searchQuery = e.target.value.trim();
                        applyFiltersAndRender();
                    }
                });
            }

            if (globalSearchButton) {
                globalSearchButton.addEventListener('click', () => {
                    if (globalSearchInput) {
                        filters.searchQuery = globalSearchInput.value.trim();
                        applyFiltersAndRender();
                    }
                });
            }

            if (sortSelect) {
                sortSelect.addEventListener('change', (e) => {
                    filters.sortBy = e.target.value;
                    applyFiltersAndRender();
                });
            }

            // Filter event listeners
            const priceRadios = document.querySelectorAll('input[name="price-bracket"]');
            priceRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    filters.priceBracket = e.target.value;
                    applyFiltersAndRender();
                });
            });

            const conditionCheckboxes = document.querySelectorAll('.condition-checkbox');
            conditionCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', (e) => {
                    if (e.target.checked) {
                        filters.conditions.add(e.target.value);
                    } else {
                        filters.conditions.delete(e.target.value);
                    }
                    applyFiltersAndRender();
                });
            });

            const campusVerifiedCheckbox = document.getElementById('campus-verified-only');
            if (campusVerifiedCheckbox) {
                campusVerifiedCheckbox.addEventListener('change', (e) => {
                    filters.campusVerifiedOnly = e.target.checked;
                    applyFiltersAndRender();
                });
            }

            // Clear filters
            const clearAllFiltersButton = document.getElementById('clear-all-filters');
            if (clearAllFiltersButton) {
                clearAllFiltersButton.addEventListener('click', () => {
                    // Reset all filters
                    filters.searchQuery = '';
                    filters.priceBracket = 'all';
                    filters.conditions.clear();
                    filters.campusVerifiedOnly = false;
                    filters.sortBy = 'relevance';

                    // Reset UI
                    if (globalSearchInput) globalSearchInput.value = '';
                    document.querySelector('input[name="price-bracket"][value="all"]').checked = true;
                    conditionCheckboxes.forEach(cb => cb.checked = false);
                    if (campusVerifiedCheckbox) campusVerifiedCheckbox.checked = false;
                    if (sortSelect) sortSelect.value = 'relevance';

                    applyFiltersAndRender();
                });
            }

            // Active filter chips
            if (activeFiltersContainer) {
                activeFiltersContainer.addEventListener('click', (e) => {
                    const button = e.target.closest('button[data-filter-type]');
                    if (!button) return;
                    
                    const type = button.getAttribute('data-filter-type');
                    const value = button.getAttribute('data-filter-value');

                    switch (type) {
                        case 'search':
                            filters.searchQuery = '';
                            if (globalSearchInput) globalSearchInput.value = '';
                            break;
                        case 'price':
                            filters.priceBracket = 'all';
                            document.querySelector('input[name="price-bracket"][value="all"]').checked = true;
                            break;
                        case 'condition':
                            if (value) {
                                filters.conditions.delete(value);
                                const checkbox = document.querySelector(`.condition-checkbox[value="${value}"]`);
                                if (checkbox) checkbox.checked = false;
                            }
                            break;
                        case 'campus':
                            filters.campusVerifiedOnly = false;
                            if (campusVerifiedCheckbox) campusVerifiedCheckbox.checked = false;
                            break;
                    }

                    applyFiltersAndRender();
                });
            }

            // Listen for search events from header
            window.addEventListener('virtuosaSearch', (e) => {
                const query = e.detail?.query || '';
                filters.searchQuery = query;
                if (globalSearchInput) {
                    globalSearchInput.value = query;
                }
                applyFiltersAndRender();
            });

            // Listen for category events from header
            window.addEventListener('virtuosaCategory', (e) => {
                const category = e.detail?.category || null;
                console.log('Category event received:', category);
                
                // Update current category
                currentCategory = (category === 'Other') ? null : category;
                
                // Update URL to reflect the new category
                const newUrl = currentCategory 
                    ? `/products?category=${encodeURIComponent(currentCategory)}`
                    : '/products';
                
                // Update browser history
                history.pushState({}, '', newUrl);
                
                // Fetch fresh data for the new category
                fetchProducts();
            });

            // Handle browser back/forward buttons
            window.addEventListener('popstate', (e) => {
                console.log('Popstate event detected, reloading products');
                // Reload products when user navigates with back/forward buttons
                fetchProducts();
            });

            // Initialize
            await fetchProducts();
        }
    </script>
    
    <!-- Clean URL Support -->
    <script src="../js/router.js"></script>
    <script src="../js/url-helper.js"></script>
    <script src="../js/image-optimizer.js"></script>
    <script src="../js/cache-manager.js"></script>
    <script src="../js/debounce.js"></script>
    <script src="../js/api-batcher.js"></script>

    <!-- Cookie Analytics & Consent -->
    <script src="/js/cookie-consent.js"></script>
    <script src="/js/cookie-tracker.js"></script>
</body>

</html>
