                        <i class="fab fa-x-twitter fa-lg"></i>
                    </a>
                    <a href="https://www.instagram.com/virtuosa_official_zm?igsh=bjV0ZHQwN2hmaDRq&ut-m_source=qr" target="_blank"
                        class="text-gray-400 hover:text-gold transition-colors">
