                <ul class="text-sm space-y-2">
                    <li><a href="/faq" class="hover:text-gold transition-colors">FAQ</a></li>
                    <li><a href="/contact" class="hover:text-gold transition-colors">Contact Support</a></li>
                    <li><a href="/live-chat" class="hover:text-gold transition-colors">Live Chat</a></li>
                </ul>
