<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maintenance Management - Virtuosa Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="../css/style.css">
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
        }
        .maintenance-active {
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
    </style>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
    
    <!-- Mobile Header Structure (320px-480px) -->
    <header class="bg-navy text-white shadow-lg sticky top-0 z-50">
        <!-- Row 1: Utilities and Branding -->
        <div class="v-container mobile-header-row-1">
            <div class="flex items-center justify-between py-3">
                <!-- Hamburger Menu (Left) -->
                <button id="mobile-menu-toggle" class="v-touch text-white hover:text-gold transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>

                <!-- Brand Name (Center) -->
                <div class="flex-1 text-center">
                    <a href="../index.html" class="text-2xl md:text-3xl font-bold text-gold mobile-logo">Virtuosa</a>
                </div>

                <!-- Customer Utilities (Right) -->
                <div class="flex items-center space-x-2 mobile-header-actions">
                    <!-- Cart Icon with Badge -->
                    <a href="cart.html" class="relative v-touch text-white hover:text-gold transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.185 1.706.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span class="cart-badge-count absolute -top-1 -right-1 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-red-100 transform translate-x-1/2 -translate-y-1/2 bg-red-600 rounded-full">0</span>
                    </a>
                    
                    <!-- Combined Notifications (includes messages) -->
                    <a href="notifications.html" class="relative v-touch text-white hover:text-gold transition-colors">
                        <i class="fas fa-bell"></i>
                        <span id="mobile-notification-badge" class="absolute -top-1 -right-1 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-bold leading-none text-red-100 transform translate-x-1/2 -translate-y-1/2 bg-red-600 rounded-full hidden">0</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="v-container v-header-row desktop-header">
            <div class="v-header-row-upper">
                <div class="v-header-logo">
                    <a href="../index.html" class="text-2xl md:text-3xl font-bold text-gold">Virtuosa</a>
                </div>
                <div class="v-header-search">
                    <div class="relative">
                        <input id="home-search-input" type="text"
                            placeholder="Search campus marketplace..."
                            class="w-full text-sm focus:outline-none focus:ring-1 focus:ring-gold"
                            autocomplete="off">
                        <button id="home-search-button" class="flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                        </button>
                        <div id="home-search-suggestions"
                            class="absolute top-full left-0 mt-1 w-full bg-gray-900 border border-gray-700 rounded-xl shadow-2xl max-h-96 overflow-y-auto hidden z-[60]">
                        </div>
                    </div>
                </div>
                <div id="user-info-container" class="v-header-actions">
                    <a href="login.html" id="login-link"
                        class="text-white hover:text-gold transition-colors font-medium hidden md:flex flex-col items-start leading-tight group">
                        <span class="text-[10px] text-gray-400 font-normal">Welcome</span>
                        <div class="flex items-center -mt-0.5">
                            <span class="text-sm font-semibold">Sign In</span>
                            <i class="fas fa-chevron-down text-[8px] ml-1 opacity-60 group-hover:rotate-180 transition-transform"></i>
                        </div>
                    </a>
                    <div id="user-menu" class="relative hidden">
                        <button onclick="toggleUserMenu()"
                            class="text-white hover:text-gold transition-colors font-medium flex flex-col items-start leading-tight">
                            <span id="user-greeting" class="text-[10px] text-gray-400 font-normal"></span>
                            <div class="flex items-center -mt-0.5">
                                <span class="text-sm font-semibold">My Account</span>
                                <i class="fas fa-chevron-down text-[8px] ml-1 opacity-60"></i>
                            </div>
                        </button>
                        <div id="user-dropdown"
                            class="absolute right-0 top-full mt-2 w-56 bg-navy rounded-xl shadow-2xl z-[60] py-4 text-white hidden border border-gray-800">
                            <div class="px-4 pb-4 border-b border-gray-800 mb-2">
                                <a href="profile.html" class="bg-button-gold text-white text-center py-2 px-4 rounded-lg text-sm block font-semibold hover:bg-gold transition-colors">My Profile</a>
                            </div>
                            <div class="px-2">
                                <a href="buyer-dashboard.html" class="flex items-center px-3 py-2 text-xs rounded-lg hover:bg-gray-800 transition-colors">
                                    <i class="fas fa-th-large mr-3 text-gray-400"></i>Dashboard
                                </a>
                                <a href="orders.html" class="flex items-center px-3 py-2 text-xs rounded-lg hover:bg-gray-800 transition-colors">
                                    <i class="fas fa-shopping-bag mr-3 text-gray-400"></i>My Orders
                                </a>
                                <div id="seller-links" class="hidden">
                                    <div class="border-t border-gray-800 my-1"></div>
                                    <a href="seller-dashboard.html" class="flex items-center px-3 py-2 text-xs rounded-lg hover:bg-gray-800 transition-colors text-green-400">
                                        <i class="fas fa-store mr-3"></i>Seller Panel
                                    </a>
                                </div>
                                <div id="admin-link" class="hidden">
                                    <div class="border-t border-gray-800 my-1"></div>
                                    <a href="admin-dashboard.html" class="flex items-center px-3 py-2 text-xs rounded-lg hover:bg-gray-800 transition-colors text-red-400">
                                        <i class="fas fa-cog mr-3"></i>Admin Panel
                                    </a>
                                </div>
                                <div class="border-t border-gray-800 my-2"></div>
                                <button onclick="logout()" class="flex items-center w-full px-3 py-2 text-xs rounded-lg hover:bg-gray-800 transition-colors text-gray-300">
                                    <i class="fas fa-sign-out-alt mr-3"></i>Sign Out
                                </button>
                            </div>
                        </div>
                    </div>

                    <a href="messages.html" class="badge-container text-white hover:text-gold transition-colors flex flex-col items-center">
                        <i class="fas fa-envelope text-lg"></i>
                        <span class="badge message-badge-count hidden">0</span>
                        <span class="text-[9px] mt-0.5 font-medium">Messages</span>
                    </a>

                    <a href="notifications.html" class="badge-container text-white hover:text-gold transition-colors flex flex-col items-center">
                        <i class="fas fa-bell text-lg"></i>
                        <span id="notification-badge-count" class="badge hidden">0</span>
                        <span class="text-[9px] mt-0.5 font-medium">Alerts</span>
                    </a>

                    <a href="cart.html" class="badge-container text-white hover:text-gold transition-colors flex flex-col items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.185 1.706.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span class="badge cart-badge-count">0</span>
                        <span class="text-[9px] mt-0.5 font-medium">Cart</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow py-8">
        <div class="container mx-auto px-4">
            <!-- Header -->
            <div class="mb-8">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-navy mb-2">Maintenance Management</h1>
                        <p class="text-gray-600">Manage system maintenance and service disruptions</p>
                    </div>
                    <a href="admin-dashboard.html" class="text-navy hover:text-gold font-medium">
                        <i class="fas fa-arrow-left mr-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>

            <!-- Active Maintenance Alert -->
            <div id="activeMaintenanceAlert" class="hidden mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-red-600 text-xl maintenance-active"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-red-800">Active Maintenance Mode</h3>
                        <div class="mt-2 text-sm text-red-700">
                            <p id="activeMaintenanceInfo"></p>
                            <div class="mt-2">
                                <button onclick="deactivateMaintenance()" class="bg-red-600 text-white px-3 py-1 rounded text-sm hover:bg-red-700">
                                    <i class="fas fa-power-off mr-1"></i>Deactivate Now
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm">Active Now</p>
                            <p id="activeCount" class="text-2xl font-bold text-red-600">0</p>
                        </div>
                        <div class="bg-red-100 p-3 rounded-full">
                            <i class="fas fa-tools text-red-600 text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm">Scheduled</p>
                            <p id="scheduledCount" class="text-2xl font-bold text-orange-600">0</p>
                        </div>
                        <div class="bg-orange-100 p-3 rounded-full">
                            <i class="fas fa-clock text-orange-600 text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm">Completed (30d)</p>
                            <p id="completedCount" class="text-2xl font-bold text-green-600">0</p>
                        </div>
                        <div class="bg-green-100 p-3 rounded-full">
                            <i class="fas fa-check-circle text-green-600 text-xl"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm">Total Events</p>
                            <p id="totalCount" class="text-2xl font-bold text-navy">0</p>
                        </div>
                        <div class="bg-blue-100 p-3 rounded-full">
                            <i class="fas fa-list text-blue-600 text-xl"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="bg-white rounded-lg shadow p-6 mb-6">
                <div class="flex flex-wrap gap-4">
                    <button onclick="showCreateModal()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                        <i class="fas fa-plus mr-2"></i>Schedule Maintenance
                    </button>
                    <button onclick="showEmergencyModal()" class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition-colors">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Emergency Maintenance
                    </button>
                    <button onclick="refreshData()" class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors">
                        <i class="fas fa-sync-alt mr-2"></i>Refresh
                    </button>
                </div>
            </div>

            <!-- Filters -->
            <div class="bg-white rounded-lg shadow p-6 mb-6">
                <div class="flex flex-wrap items-center gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Status Filter</label>
                        <select id="statusFilter" onchange="loadMaintenanceData()" class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="all">All Status</option>
                            <option value="planned">Planned</option>
                            <option value="active">Active</option>
                            <option value="completed">Completed</option>
                            <option value="cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Type Filter</label>
                        <select id="typeFilter" onchange="loadMaintenanceData()" class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="all">All Types</option>
                            <option value="scheduled">Scheduled</option>
                            <option value="emergency">Emergency</option>
                            <option value="routine">Routine</option>
                            <option value="security">Security</option>
                        </select>
                    </div>
                    <div class="flex-1">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Search</label>
                        <input type="text" id="searchInput" placeholder="Search by title or description..." 
                               onkeyup="searchMaintenance()" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    </div>
                </div>
            </div>

            <!-- Maintenance Table -->
            <div class="bg-white rounded-lg shadow overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="maintenanceTableBody" class="bg-white divide-y divide-gray-200">
                            <!-- Maintenance records will be loaded here -->
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                <div id="pagination" class="px-6 py-4 bg-gray-50 border-t border-gray-200">
                    <!-- Pagination will be loaded here -->
                </div>
            </div>
        </div>
    </main>

    <!-- Create/Edit Maintenance Modal -->
    <div id="maintenanceModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4" 
         role="dialog" aria-modal="true" aria-labelledby="maintenanceModalTitle">
        <div class="bg-white rounded-lg max-w-4xl w-full p-6 max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-4">
                <h3 id="maintenanceModalTitle" class="text-xl font-bold text-navy">Schedule Maintenance</h3>
                <button onclick="closeMaintenanceModal()" class="text-gray-400 hover:text-gray-600" 
                        aria-label="Close modal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="maintenanceForm" onsubmit="saveMaintenance(event)">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Basic Information -->
                    <div class="space-y-4">
                        <h4 class="font-semibold text-gray-900 border-b pb-2">Basic Information</h4>
                        
                        <div>
                            <label for="title" class="block text-sm font-medium text-gray-700 mb-2">Title *</label>
                            <input type="text" id="title" name="title" required maxlength="100"
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        
                        <div>
                            <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description *</label>
                            <textarea id="description" name="description" required maxlength="1000" rows="3"
                                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="type" class="block text-sm font-medium text-gray-700 mb-2">Type *</label>
                                <select id="type" name="type" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="scheduled">Scheduled</option>
                                    <option value="emergency">Emergency</option>
                                    <option value="routine">Routine</option>
                                    <option value="security">Security</option>
                                </select>
                            </div>
                            
                            <div>
                                <label for="priority" class="block text-sm font-medium text-gray-700 mb-2">Priority *</label>
                                <select id="priority" name="priority" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option value="low">Low</option>
                                    <option value="medium">Medium</option>
                                    <option value="high">High</option>
                                    <option value="critical">Critical</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Schedule Settings -->
                    <div class="space-y-4">
                        <h4 class="font-semibold text-gray-900 border-b pb-2">Schedule Settings</h4>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="scheduledStartTime" class="block text-sm font-medium text-gray-700 mb-2">Start Time *</label>
                                <input type="datetime-local" id="scheduledStartTime" name="scheduledStartTime" required
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                            
                            <div>
                                <label for="scheduledEndTime" class="block text-sm font-medium text-gray-700 mb-2">End Time *</label>
                                <input type="datetime-local" id="scheduledEndTime" name="scheduledEndTime" required
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                        </div>
                        
                        <div>
                            <label for="targetAudience" class="block text-sm font-medium text-gray-700 mb-2">Target Audience</label>
                            <select id="targetAudience" name="targetAudience" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                <option value="all_users">All Users</option>
                                <option value="buyers_only">Buyers Only</option>
                                <option value="sellers_only">Sellers Only</option>
                                <option value="verified_users">Verified Users</option>
                                <option value="specific_users">Specific Users</option>
                            </select>
                        </div>
                        
                        <div class="flex items-center">
                            <input type="checkbox" id="allowAdminAccess" name="allowAdminAccess" checked
                                   class="mr-2 border border-gray-300 rounded">
                            <label for="allowAdminAccess" class="text-sm text-gray-700">Allow admin access during maintenance</label>
                        </div>
                    </div>
                </div>
                
                <!-- Affected Services -->
                <div class="mt-6">
                    <h4 class="font-semibold text-gray-900 mb-4">Affected Services</h4>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="user_registration" class="mr-2">
                            <span class="text-sm">User Registration</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="user_login" class="mr-2">
                            <span class="text-sm">User Login</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="product_browsing" class="mr-2">
                            <span class="text-sm">Product Browsing</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="product_purchasing" class="mr-2">
                            <span class="text-sm">Product Purchasing</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="seller_dashboard" class="mr-2">
                            <span class="text-sm">Seller Dashboard</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="messaging" class="mr-2">
                            <span class="text-sm">Messaging</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="notifications" class="mr-2">
                            <span class="text-sm">Notifications</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="affectedServices" value="search" class="mr-2">
                            <span class="text-sm">Search</span>
                        </label>
                    </div>
                </div>
                
                <!-- Message Content -->
                <div class="mt-6">
                    <h4 class="font-semibold text-gray-900 mb-4">User Message Content</h4>
                    <div class="space-y-4">
                        <div>
                            <label for="messageHeadline" class="block text-sm font-medium text-gray-700 mb-2">Headline</label>
                            <input type="text" id="messageHeadline" name="messageHeadline" maxlength="200"
                                   placeholder="e.g., Scheduled Maintenance Tonight"
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        
                        <div>
                            <label for="messageBody" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
                            <textarea id="messageBody" name="messageBody" maxlength="2000" rows="3"
                                      placeholder="Explain what's happening and what users should expect..."
                                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="actionButton" class="block text-sm font-medium text-gray-700 mb-2">Action Button Text</label>
                                <input type="text" id="actionButton" name="actionButton" maxlength="50"
                                       placeholder="e.g., Learn More"
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                            
                            <div>
                                <label for="actionUrl" class="block text-sm font-medium text-gray-700 mb-2">Action URL</label>
                                <input type="url" id="actionUrl" name="actionUrl"
                                       placeholder="https://example.com/maintenance"
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Notification Settings -->
                <div class="mt-6">
                    <h4 class="font-semibold text-gray-900 mb-4">Notification Settings</h4>
                    <div class="space-y-3">
                        <label class="flex items-center">
                            <input type="checkbox" name="sendEmail" checked class="mr-2">
                            <span class="text-sm">Send email notifications</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="sendPush" checked class="mr-2">
                            <span class="text-sm">Send push notifications</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="sendInApp" checked class="mr-2">
                            <span class="text-sm">Send in-app notifications</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="sendSMS" class="mr-2">
                            <span class="text-sm">Send SMS notifications</span>
                        </label>
                        
                        <div class="grid grid-cols-2 gap-4 mt-4">
                            <div>
                                <label for="notifyHoursBefore" class="block text-sm font-medium text-gray-700 mb-2">Notify (hours before)</label>
                                <input type="number" id="notifyHoursBefore" name="notifyHoursBefore" value="24" min="1" max="168"
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="flex justify-end space-x-3 mt-8 pt-6 border-t">
                    <button type="button" onclick="closeMaintenanceModal()" class="px-4 py-2 text-gray-600 hover:text-gray-800 font-medium">
                        Cancel
                    </button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium">
                        <i class="fas fa-save mr-2"></i>Save Maintenance
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Maintenance Details Modal -->
    <div id="detailsModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4" 
         role="dialog" aria-modal="true" aria-labelledby="detailsModalTitle">
        <div class="bg-white rounded-lg max-w-4xl w-full p-6 max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-4">
                <h3 id="detailsModalTitle" class="text-xl font-bold text-navy">Maintenance Details</h3>
                <button onclick="closeDetailsModal()" class="text-gray-400 hover:text-gray-600" 
                        aria-label="Close modal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div id="maintenanceDetails">
                <!-- Maintenance details will be loaded here -->
            </div>
        </div>
    </div>

    <script src="../js/config.js"></script>
    <script src="../js/admin-auth-helper.js"></script>
    <script>
        let currentPage = 1;
        const pageSize = 20;
        let currentMaintenanceId = null;
        let allMaintenance = [];

        document.addEventListener('DOMContentLoaded', async () => {
            // Check admin access first
            const hasAccess = await checkAdminAccess();
            if (!hasAccess) {
                return;
            }
            
            const token = localStorage.getItem('token');
            if (!token) {
                window.location.href = '/pages/login.html';
                return;
            }

            await loadMaintenanceData();
            await checkActiveMaintenance();
            
            // Set default datetime values (current time + 1 hour, + 2 hours)
            const now = new Date();
            const startTime = new Date(now.getTime() + 60 * 60 * 1000);
            const endTime = new Date(now.getTime() + 2 * 60 * 60 * 1000);
            
            document.getElementById('scheduledStartTime').value = formatDateTimeLocal(startTime);
            document.getElementById('scheduledEndTime').value = formatDateTimeLocal(endTime);
        });

        function formatDateTimeLocal(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        async function loadMaintenanceData(page = 1) {
            try {
                const status = document.getElementById('statusFilter').value;
                const type = document.getElementById('typeFilter').value;
                
                let url = `${API_BASE}/admin/maintenance?page=${page}&limit=${pageSize}`;
                if (status !== 'all') url += `&status=${status}`;
                if (type !== 'all') url += `&type=${type}`;
                
                const response = await fetch(url, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    const data = await response.json();
                    allMaintenance = data.maintenance;
                    renderMaintenanceTable(data.maintenance);
                    renderPagination(data.pagination);
                    updateStats(data.maintenance);
                } else if (response.status === 401 || response.status === 403) {
                    localStorage.removeItem('token');
                    localStorage.removeItem('user');
                    window.location.href = '/pages/login.html';
                    return;
                } else {
                    throw new Error('Failed to load maintenance data');
                }
            } catch (error) {
                console.error('Load maintenance data error:', error);
                showToast('Failed to load maintenance data', 'error');
            }
        }

        function renderMaintenanceTable(maintenance) {
            const tbody = document.getElementById('maintenanceTableBody');
            
            if (maintenance.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                            <i class="fas fa-tools text-4xl mb-2"></i>
                            <p>No maintenance records found</p>
                        </td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = maintenance.map(record => `
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                        <div class="text-sm font-medium text-gray-900">${escapeHtml(record.title)}</div>
                        <div class="text-sm text-gray-500 truncate max-w-xs">${escapeHtml(record.description)}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            ${record.type === 'emergency' ? 'bg-red-100 text-red-800' : ''}
                            ${record.type === 'scheduled' ? 'bg-blue-100 text-blue-800' : ''}
                            ${record.type === 'routine' ? 'bg-gray-100 text-gray-800' : ''}
                            ${record.type === 'security' ? 'bg-purple-100 text-purple-800' : ''}">
                            ${escapeHtml(record.type)}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                            ${record.status === 'active' ? 'bg-red-100 text-red-800' : ''}
                            ${record.status === 'planned' ? 'bg-orange-100 text-orange-800' : ''}
                            ${record.status === 'completed' ? 'bg-green-100 text-green-800' : ''}
                            ${record.status === 'cancelled' ? 'bg-gray-100 text-gray-800' : ''}">
                            ${escapeHtml(record.status)}
                        </span>
                        ${record.isActive ? '<span class="ml-2 text-xs text-red-600"><i class="fas fa-circle"></i> Active</span>' : ''}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        <div>${record.scheduledStartTime ? new Date(record.scheduledStartTime).toLocaleDateString() : 'N/A'}</div>
                        <div class="text-xs">${record.scheduledStartTime ? new Date(record.scheduledStartTime).toLocaleTimeString() : ''}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        ${record.getDuration ? record.getDuration() + ' min' : 'N/A'}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <button onclick="viewDetails('${escapeHtml(record._id)}')" class="text-blue-600 hover:text-blue-900 mr-3">
                            <i class="fas fa-eye"></i> View
                        </button>
                        ${record.status === 'planned' ? `
                            <button onclick="activateMaintenance('${escapeHtml(record._id)}')" class="text-green-600 hover:text-green-900 mr-3">
                                <i class="fas fa-play"></i> Activate
                            </button>
                        ` : ''}
                        ${record.status === 'active' ? `
                            <button onclick="deactivateMaintenance('${escapeHtml(record._id)}')" class="text-red-600 hover:text-red-900 mr-3">
                                <i class="fas fa-stop"></i> Stop
                            </button>
                        ` : ''}
                        ${record.status === 'planned' || record.status === 'active' ? `
                            <button onclick="editMaintenance('${escapeHtml(record._id)}')" class="text-yellow-600 hover:text-yellow-900 mr-3">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        ` : ''}
                        ${record.status !== 'active' ? `
                            <button onclick="deleteMaintenance('${escapeHtml(record._id)}')" class="text-red-600 hover:text-red-900">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        ` : ''}
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(pagination) {
            const container = document.getElementById('pagination');
            
            if (pagination.pages <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = '<div class="flex items-center justify-between">';
            html += '<div class="text-sm text-gray-700">';
            html += `Showing ${((pagination.current - 1) * pageSize) + 1} to ${Math.min(pagination.current * pageSize, pagination.total)} of ${pagination.total} results`;
            html += '</div>';
            
            html += '<div class="flex items-center space-x-2">';
            
            // Previous button
            if (pagination.current > 1) {
                html += `<button onclick="loadMaintenanceData(${pagination.current - 1})" class="px-3 py-1 border border-gray-300 rounded-md hover:bg-gray-50">Previous</button>`;
            }
            
            // Page numbers
            for (let i = 1; i <= pagination.pages; i++) {
                if (i === pagination.current) {
                    html += `<button class="px-3 py-1 bg-blue-600 text-white rounded-md">${i}</button>`;
                } else if (Math.abs(i - pagination.current) <= 2) {
                    html += `<button onclick="loadMaintenanceData(${i})" class="px-3 py-1 border border-gray-300 rounded-md hover:bg-gray-50">${i}</button>`;
                }
            }
            
            // Next button
            if (pagination.current < pagination.pages) {
                html += `<button onclick="loadMaintenanceData(${pagination.current + 1})" class="px-3 py-1 border border-gray-300 rounded-md hover:bg-gray-50">Next</button>`;
            }
            
            html += '</div></div>';
            container.innerHTML = html;
        }

        function updateStats(maintenance) {
            const active = maintenance.filter(m => m.isActive).length;
            const planned = maintenance.filter(m => m.status === 'planned').length;
            const thirtyDaysAgo = new Date();
            thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
            const completed = maintenance.filter(m => 
                m.status === 'completed' && 
                new Date(m.actualEndTime || m.createdAt) > thirtyDaysAgo
            ).length;

            document.getElementById('activeCount').textContent = active;
            document.getElementById('scheduledCount').textContent = planned;
            document.getElementById('completedCount').textContent = completed;
            document.getElementById('totalCount').textContent = maintenance.length;
        }

        async function checkActiveMaintenance() {
            try {
                const response = await fetch(`${API_BASE}/maintenance/status`);
                if (response.ok) {
                    const data = await response.json();
                    if (data.isActive && data.activeMaintenance) {
                        showActiveMaintenanceAlert(data.activeMaintenance);
                    }
                }
            } catch (error) {
                console.error('Check active maintenance error:', error);
            }
        }

        function showActiveMaintenanceAlert(maintenance) {
            const alert = document.getElementById('activeMaintenanceAlert');
            const info = document.getElementById('activeMaintenanceInfo');
            
            info.innerHTML = `
                <strong>${escapeHtml(maintenance.title)}</strong><br>
                Type: ${escapeHtml(maintenance.type)} | Priority: ${escapeHtml(maintenance.priority)}<br>
                Started: ${maintenance.actualStartTime ? new Date(maintenance.actualStartTime).toLocaleString() : 'Unknown'}<br>
                Services affected: ${maintenance.affectedServices ? maintenance.affectedServices.join(', ') : 'All services'}
            `;
            
            alert.classList.remove('hidden');
            currentMaintenanceId = maintenance.id;
        }

        function showCreateModal() {
            currentMaintenanceId = null;
            document.getElementById('maintenanceModalTitle').textContent = 'Schedule Maintenance';
            document.getElementById('maintenanceForm').reset();
            
            // Reset default datetime values
            const now = new Date();
            const startTime = new Date(now.getTime() + 60 * 60 * 1000);
            const endTime = new Date(now.getTime() + 2 * 60 * 60 * 1000);
            
            document.getElementById('scheduledStartTime').value = formatDateTimeLocal(startTime);
            document.getElementById('scheduledEndTime').value = formatDateTimeLocal(endTime);
            
            document.getElementById('maintenanceModal').classList.remove('hidden');
        }

        function showEmergencyModal() {
            currentMaintenanceId = null;
            document.getElementById('maintenanceModalTitle').textContent = 'Emergency Maintenance';
            document.getElementById('maintenanceForm').reset();
            
            // Set emergency defaults
            const now = new Date();
            const startTime = new Date(now.getTime() + 5 * 60 * 1000); // 5 minutes from now
            const endTime = new Date(now.getTime() + 2 * 60 * 60 * 1000); // 2 hours from now
            
            document.getElementById('title').value = 'Emergency Maintenance';
            document.getElementById('type').value = 'emergency';
            document.getElementById('priority').value = 'critical';
            document.getElementById('scheduledStartTime').value = formatDateTimeLocal(startTime);
            document.getElementById('scheduledEndTime').value = formatDateTimeLocal(endTime);
            document.getElementById('messageHeadline').value = 'Emergency Maintenance in Progress';
            document.getElementById('messageBody').value = 'We are performing emergency maintenance to resolve critical issues. Service may be temporarily unavailable.';
            
            document.getElementById('maintenanceModal').classList.remove('hidden');
        }

        function closeMaintenanceModal() {
            document.getElementById('maintenanceModal').classList.add('hidden');
            document.getElementById('maintenanceForm').reset();
        }

        async function saveMaintenance(event) {
            event.preventDefault();
            
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());
            
            // Handle checkboxes
            data.affectedServices = formData.getAll('affectedServices');
            data.notificationSettings = {
                sendEmail: formData.has('sendEmail'),
                sendPush: formData.has('sendPush'),
                sendInApp: formData.has('sendInApp'),
                sendSMS: formData.has('sendSMS'),
                notifyHoursBefore: parseInt(data.notifyHoursBefore) || 24
            };
            
            // Handle message content
            data.messageContent = {
                headline: data.messageHeadline,
                body: data.messageBody,
                actionButton: data.actionButton,
                actionUrl: data.actionUrl
            };
            
            // Clean up the data
            delete data.messageHeadline;
            delete data.messageBody;
            delete data.actionButton;
            delete data.actionUrl;
            delete data.notifyHoursBefore;
            delete data.sendEmail;
            delete data.sendPush;
            delete data.sendInApp;
            delete data.sendSMS;
            
            try {
                let response;
                if (currentMaintenanceId) {
                    response = await fetch(`${API_BASE}/admin/maintenance/${currentMaintenanceId}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${localStorage.getItem('token')}`
                        },
                        body: JSON.stringify(data)
                    });
                } else {
                    response = await fetch(`${API_BASE}/admin/maintenance`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${localStorage.getItem('token')}`
                        },
                        body: JSON.stringify(data)
                    });
                }

                if (response.ok) {
                    showToast(currentMaintenanceId ? 'Maintenance updated successfully' : 'Maintenance scheduled successfully', 'success');
                    closeMaintenanceModal();
                    await loadMaintenanceData();
                    await checkActiveMaintenance();
                } else {
                    const error = await response.json();
                    throw new Error(error.error || 'Failed to save maintenance');
                }
            } catch (error) {
                console.error('Save maintenance error:', error);
                showToast(error.message || 'Failed to save maintenance', 'error');
            }
        }

        async function viewDetails(maintenanceId) {
            try {
                const response = await fetch(`${API_BASE}/admin/maintenance/${maintenanceId}`, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    const maintenance = await response.json();
                    showMaintenanceDetails(maintenance);
                } else {
                    throw new Error('Failed to load maintenance details');
                }
            } catch (error) {
                console.error('View details error:', error);
                showToast('Failed to load maintenance details', 'error');
            }
        }

        function showMaintenanceDetails(maintenance) {
            const detailsDiv = document.getElementById('maintenanceDetails');
            detailsDiv.innerHTML = `
                <div class="space-y-6">
                    <!-- Basic Information -->
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-2">Basic Information</h4>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div><span class="font-medium">Title:</span> ${escapeHtml(maintenance.title)}</div>
                                <div><span class="font-medium">Type:</span> ${escapeHtml(maintenance.type)}</div>
                                <div><span class="font-medium">Priority:</span> ${escapeHtml(maintenance.priority)}</div>
                                <div><span class="font-medium">Status:</span> ${escapeHtml(maintenance.status)}</div>
                                <div><span class="font-medium">Created By:</span> ${escapeHtml(maintenance.createdBy?.fullName || 'Unknown')}</div>
                                <div><span class="font-medium">Created At:</span> ${maintenance.createdAt ? new Date(maintenance.createdAt).toLocaleString() : 'N/A'}</div>
                            </div>
                            <div class="mt-3">
                                <span class="font-medium">Description:</span>
                                <p class="text-gray-700 mt-1">${escapeHtml(maintenance.description)}</p>
                            </div>
                        </div>
                    </div>

                    <!-- Schedule Information -->
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-2">Schedule Information</h4>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div><span class="font-medium">Scheduled Start:</span> ${maintenance.scheduledStartTime ? new Date(maintenance.scheduledStartTime).toLocaleString() : 'N/A'}</div>
                                <div><span class="font-medium">Scheduled End:</span> ${maintenance.scheduledEndTime ? new Date(maintenance.scheduledEndTime).toLocaleString() : 'N/A'}</div>
                                <div><span class="font-medium">Actual Start:</span> ${maintenance.actualStartTime ? new Date(maintenance.actualStartTime).toLocaleString() : 'Not started'}</div>
                                <div><span class="font-medium">Actual End:</span> ${maintenance.actualEndTime ? new Date(maintenance.actualEndTime).toLocaleString() : 'Not completed'}</div>
                                <div><span class="font-medium">Duration:</span> ${maintenance.getDuration ? maintenance.getDuration() + ' minutes' : 'N/A'}</div>
                                <div><span class="font-medium">Admin Access:</span> ${maintenance.allowAdminAccess ? 'Allowed' : 'Blocked'}</div>
                            </div>
                        </div>
                    </div>

                    <!-- Affected Services -->
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-2">Affected Services</h4>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="flex flex-wrap gap-2">
                                ${(maintenance.affectedServices || []).map(service => 
                                    `<span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">${escapeHtml(service)}</span>`
                                ).join('') || '<span class="text-gray-500">All services</span>'}
                            </div>
                        </div>
                    </div>

                    <!-- Metrics -->
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-2">Metrics</h4>
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div><span class="font-medium">Users Notified:</span> ${maintenance.metrics?.usersNotified || 0}</div>
                                <div><span class="font-medium">Messages Sent:</span> ${maintenance.metrics?.messagesSent || 0}</div>
                                <div><span class="font-medium">Users Affected:</span> ${maintenance.metrics?.usersAffected || 0}</div>
                                <div><span class="font-medium">Complaints:</span> ${maintenance.metrics?.complaintsReceived || 0}</div>
                            </div>
                        </div>
                    </div>

                    <!-- Reports -->
                    ${maintenance.reports && maintenance.reports.length > 0 ? `
                        <div>
                            <h4 class="font-semibold text-gray-900 mb-2">Reports</h4>
                            <div class="bg-gray-50 rounded-lg p-4">
                                <div class="space-y-3">
                                    ${maintenance.reports.map(report => `
                                        <div class="border-l-4 ${report.severity === 'critical' ? 'border-red-500' : report.severity === 'error' ? 'border-orange-500' : report.severity === 'warning' ? 'border-yellow-500' : 'border-blue-500'} pl-3">
                                            <div class="text-sm">
                                                <div class="font-medium">${escapeHtml(report.type)}</div>
                                                <div class="text-gray-700">${escapeHtml(report.message)}</div>
                                                <div class="text-xs text-gray-500 mt-1">
                                                    ${new Date(report.timestamp).toLocaleString()} - ${report.reportedBy?.fullName || 'System'}
                                                </div>
                                            </div>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        </div>
                    ` : ''}

                    <!-- Actions -->
                    <div class="flex justify-end space-x-3 pt-4 border-t">
                        ${maintenance.status === 'planned' ? `
                            <button onclick="activateMaintenance('${escapeHtml(maintenance._id)}')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                                <i class="fas fa-play mr-2"></i>Activate Now
                            </button>
                        ` : ''}
                        ${maintenance.status === 'active' ? `
                            <button onclick="deactivateMaintenance('${escapeHtml(maintenance._id)}')" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                                <i class="fas fa-stop mr-2"></i>Deactivate Now
                            </button>
                        ` : ''}
                        ${maintenance.status === 'planned' || maintenance.status === 'active' ? `
                            <button onclick="editMaintenance('${escapeHtml(maintenance._id)}')" class="px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition-colors">
                                <i class="fas fa-edit mr-2"></i>Edit
                            </button>
                        ` : ''}
                        <button onclick="sendNotifications('${escapeHtml(maintenance._id)}')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                            <i class="fas fa-bell mr-2"></i>Send Notifications
                        </button>
                    </div>
                </div>
            `;

            document.getElementById('detailsModal').classList.remove('hidden');
        }

        function closeDetailsModal() {
            document.getElementById('detailsModal').classList.add('hidden');
        }

        async function activateMaintenance(maintenanceId) {
            if (!confirm('Are you sure you want to activate this maintenance now? This will immediately put the site into maintenance mode.')) {
                return;
            }

            try {
                const response = await fetch(`${API_BASE}/admin/maintenance/${maintenanceId}/activate`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    showToast('Maintenance activated successfully', 'success');
                    await loadMaintenanceData();
                    await checkActiveMaintenance();
                } else {
                    throw new Error('Failed to activate maintenance');
                }
            } catch (error) {
                console.error('Activate maintenance error:', error);
                showToast('Failed to activate maintenance', 'error');
            }
        }

        async function deactivateMaintenance(maintenanceId = currentMaintenanceId) {
            if (!confirm('Are you sure you want to deactivate this maintenance? This will restore normal site access.')) {
                return;
            }

            try {
                const response = await fetch(`${API_BASE}/admin/maintenance/${maintenanceId}/deactivate`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    showToast('Maintenance deactivated successfully', 'success');
                    document.getElementById('activeMaintenanceAlert').classList.add('hidden');
                    currentMaintenanceId = null;
                    await loadMaintenanceData();
                    await checkActiveMaintenance();
                } else {
                    throw new Error('Failed to deactivate maintenance');
                }
            } catch (error) {
                console.error('Deactivate maintenance error:', error);
                showToast('Failed to deactivate maintenance', 'error');
            }
        }

        async function editMaintenance(maintenanceId) {
            try {
                const response = await fetch(`${API_BASE}/admin/maintenance/${maintenanceId}`, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    const maintenance = await response.json();
                    currentMaintenanceId = maintenanceId;
                    
                    // Populate form
                    document.getElementById('maintenanceModalTitle').textContent = 'Edit Maintenance';
                    document.getElementById('title').value = maintenance.title;
                    document.getElementById('description').value = maintenance.description;
                    document.getElementById('type').value = maintenance.type;
                    document.getElementById('priority').value = maintenance.priority;
                    document.getElementById('scheduledStartTime').value = maintenance.scheduledStartTime ? formatDateTimeLocal(new Date(maintenance.scheduledStartTime)) : '';
                    document.getElementById('scheduledEndTime').value = maintenance.scheduledEndTime ? formatDateTimeLocal(new Date(maintenance.scheduledEndTime)) : '';
                    document.getElementById('targetAudience').value = maintenance.targetAudience || 'all_users';
                    document.getElementById('allowAdminAccess').checked = maintenance.allowAdminAccess !== false;
                    
                    // Set affected services
                    const serviceCheckboxes = document.querySelectorAll('input[name="affectedServices"]');
                    serviceCheckboxes.forEach(checkbox => {
                        checkbox.checked = maintenance.affectedServices && maintenance.affectedServices.includes(checkbox.value);
                    });
                    
                    // Set message content
                    if (maintenance.messageContent) {
                        document.getElementById('messageHeadline').value = maintenance.messageContent.headline || '';
                        document.getElementById('messageBody').value = maintenance.messageContent.body || '';
                        document.getElementById('actionButton').value = maintenance.messageContent.actionButton || '';
                        document.getElementById('actionUrl').value = maintenance.messageContent.actionUrl || '';
                    }
                    
                    // Set notification settings
                    if (maintenance.notificationSettings) {
                        document.getElementById('sendEmail').checked = maintenance.notificationSettings.sendEmail !== false;
                        document.getElementById('sendPush').checked = maintenance.notificationSettings.sendPush !== false;
                        document.getElementById('sendInApp').checked = maintenance.notificationSettings.sendInApp !== false;
                        document.getElementById('sendSMS').checked = maintenance.notificationSettings.sendSMS === true;
                        document.getElementById('notifyHoursBefore').value = maintenance.notificationSettings.notifyHoursBefore || 24;
                    }
                    
                    document.getElementById('maintenanceModal').classList.remove('hidden');
                } else {
                    throw new Error('Failed to load maintenance for editing');
                }
            } catch (error) {
                console.error('Edit maintenance error:', error);
                showToast('Failed to load maintenance for editing', 'error');
            }
        }

        async function deleteMaintenance(maintenanceId) {
            if (!confirm('Are you sure you want to delete this maintenance record? This action cannot be undone.')) {
                return;
            }

            try {
                const response = await fetch(`${API_BASE}/admin/maintenance/${maintenanceId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (response.ok) {
                    showToast('Maintenance deleted successfully', 'success');
                    await loadMaintenanceData();
                } else {
                    const error = await response.json();
                    throw new Error(error.error || 'Failed to delete maintenance');
                }
            } catch (error) {
                console.error('Delete maintenance error:', error);
                showToast(error.message || 'Failed to delete maintenance', 'error');
            }
        }

        async function sendNotifications(maintenanceId) {
            // TODO: Implement notification sending interface
            showToast('Notification sending interface coming soon', 'info');
        }

        function searchMaintenance() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const filteredMaintenance = allMaintenance.filter(record => 
                record.title.toLowerCase().includes(searchTerm) ||
                record.description.toLowerCase().includes(searchTerm)
            );
            renderMaintenanceTable(filteredMaintenance);
        }

        async function refreshData() {
            await loadMaintenanceData();
            await checkActiveMaintenance();
            showToast('Data refreshed successfully', 'success');
        }

        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text ? text.replace(/[&<>"']/g, m => map[m]) : '';
        }

        function showToast(message, type = 'info') {
            // Simple toast implementation - you can replace with a more sophisticated one
            const toast = document.createElement('div');
            toast.className = `fixed top-4 right-4 px-4 py-2 rounded-lg text-white z-50 ${
                type === 'success' ? 'bg-green-600' : 
                type === 'error' ? 'bg-red-600' : 
                type === 'warning' ? 'bg-orange-600' : 'bg-blue-600'
            }`;
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
    </script>

    <!-- Cookie Analytics & Consent -->
    <script src="/js/cookie-consent.js"></script>
    <script src="/js/cookie-tracker.js"></script>
</body>

</html>
